{
  "env": {
    "OCTOPUS_DISABLE_BARE": "1",
    "OCTOPUS_AGENT_MAX_OUTPUT_BYTES": "0",
    "OCTOPUS_CONTEXT_BUDGET": "200000",
    "OCTOPUS_CODEX_CONTEXT_BUDGET": "400000",
    "OCTOPUS_CODEX_LARGE_CONTEXT_BUDGET": "400000",
    "OCTOPUS_GEMINI_CONTEXT_BUDGET": "1000000",
    "OCTOPUS_CLAUDE_CONTEXT_BUDGET": "1000000",
    "OCTOPUS_MAX_PARALLEL_AGENTS": "8",
    "OCTOPUS_AGENT_TIMEOUT": "3600",
    "OCTOPUS_COPILOT_TIMEOUT": "600",
    "OCTOPUS_CURSOR_AGENT_TIMEOUT": "600",
    "OCTOPUS_OPENCODE_TIMEOUT": "600",
    "OCTOPUS_GITHUB_WORK_QUEUE_LIMIT": "10",
    "CLAUDE_OCTOPUS_RALPH_MAX_ITERATIONS": "200"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\carla\\bin\\piebald-memory-selector.cmd"
          },
          {
            "type": "command",
            "command": "C:\\Users\\carla\\bin\\fullstep-wake-hook.cmd"
          },
          {
            "type": "command",
            "command": "C:\\Users\\carla\\bin\\bg-wake-hook.cmd"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\carla\\bin\\piebald-daemon-start.cmd"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\carla\\bin\\rtk-test-hook.cmd",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Agent|LaunchSubagent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Projects\\piebald-dynamic-subagents\\hooks\\pretooluse-route.cmd",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "octo@nyldn-plugins": true
  },
  "extraKnownMarketplaces": {
    "nyldn-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/nyldn/plugins.git"
      }
    }
  },
  "language": "portuguese",
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "mcpServers": {}
}